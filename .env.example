# Server-only PostgreSQL connection. Use a development Supabase project locally.
# Never prefix this value with NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres:replace-me@localhost:5432/purple_net_dev

# Administrator account created only by `npm run admin:setup`.
ADMIN_EMAIL=admin@example.com
# Use a unique, high-entropy password. This value is never logged.
ADMIN_PASSWORD=replace-with-a-long-unique-password

# Public base URL used only for redirects and test configuration.
APP_URL=http://localhost:3000

# Use test mode only with a disposable test database URL; test commands reject
# production-looking URLs.
NODE_ENV=development
